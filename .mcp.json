{
  "mcpServers": {
    "n8n-check": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/mcp/serve.js"],
      "env": {
        "N8N_HOST": "${user_config.n8n_host}",
        "N8N_API_KEY": "${user_config.n8n_api_key}",
        "N8N_CHECK_DATA_DIR": "${CLAUDE_PLUGIN_DATA}",
        "NODE_PATH": "${CLAUDE_PLUGIN_DATA}/node_modules"
      }
    }
  }
}
