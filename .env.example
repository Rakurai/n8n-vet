# n8n-vet development environment
# Copy to .env and fill in values.
# .env is gitignored — never commit secrets.

# Data directory for trust state, snapshots, and pin data cache
# N8N_VET_DATA_DIR=.n8n-vet

# ── Integration testing ──────────────────────────────────────────
# Required for `npx tsx test/integration/run.ts`

# n8n instance URL (also used by n8nac)
N8N_HOST=http://localhost:5678

# n8n REST API key (Settings → API → Create API Key)
N8N_API_KEY=

# n8n MCP server URL (default derived from N8N_HOST)
N8N_MCP_URL=http://localhost:5678/mcp-server/http

# n8n MCP server token (Settings → MCP Server → Generate Token)
# Audience must be "mcp-server-api"
N8N_MCP_TOKEN=
