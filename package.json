{
  "name": "n8n-proctor",
  "version": "0.2.0",
  "description": "Guardrailed validation control for agent-built n8n workflows",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    ".claude-plugin",
    "skills",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rakurai/n8n-proctor.git"
  },
  "bin": {
    "n8n-proctor": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "dotenv -- tsx test/integration/run.ts",
    "test:integ:check": "dotenv -- tsx test/integration/run.ts --check",
    "test:integ:seed": "dotenv -- tsx test/integration/seed.ts",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "check-version": "node scripts/check-version.js",
    "ci": "npm run typecheck && npm run lint && npm test && npm run check-version"
  },
  "keywords": [
    "n8n",
    "workflow",
    "validation",
    "testing",
    "mcp",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@n8n-as-code/transformer": "^1.2.0",
    "json-stable-stringify": "^1.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/json-stable-stringify": "^1.1.0",
    "@types/node": "^25.6.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
